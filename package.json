        },
	"devDependencies": {
		"@biomejs/biome": "^2.4.7",
		"@types/better-sqlite3": "^7.6.13",
		"@types/bun": "^1.3.10",
		"@types/uuid": "^11.0.0",
		"better-sqlite3": "^12.8.0",
