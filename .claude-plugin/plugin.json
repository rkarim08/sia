{
	"name": "sia",
	"version": "1.3.1",
	"description": "Persistent graph memory for AI coding agents — bi-temporal knowledge graph with cross-session recall",
	"author": {
		"name": "Ramez Karim"
	},
	"license": "Apache-2.0",
	"category": "development",
	"icon": "./icon.svg",
	"repository": "https://github.com/rkarim08/sia",
	"homepage": "https://github.com/rkarim08/sia#readme",
	"bugs": "https://github.com/rkarim08/sia/issues",
	"keywords": [
		"claude-code",
		"claude",
		"memory",
		"knowledge-graph",
		"mcp",
		"ai-coding",
		"persistent-memory",
		"bi-temporal",
		"agent-memory"
	],
	"mcpServers": {
		"sia": {
			"command": "bash",
			"args": ["${CLAUDE_PLUGIN_ROOT}/scripts/start-mcp.sh"],
			"env": {
				"SIA_HOME": "${CLAUDE_PLUGIN_DATA}",
				"CLAUDE_PLUGIN_DATA": "${CLAUDE_PLUGIN_DATA}",
				"CLAUDE_PLUGIN_ROOT": "${CLAUDE_PLUGIN_ROOT}"
			}
		}
	}
}
